{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$CLAUDE_FILE_PATH\" in *.go) gofumpt -w \"$CLAUDE_FILE_PATH\" ;; esac",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$CLAUDE_FILE_PATH\" in *.go) go test -count=1 -short ./... 2>&1 | tail -1 ;; esac",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__apple-eventkit__calendar_list_events",
      "Bash(claude mcp list *)",
      "Bash(task check*)",
      "Bash(claude --version*)"
    ]
  }
}
